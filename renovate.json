{
  "extends": ["github>browniebroke/renovate-configs:python"],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/)scripts/setup\\.sh$",
        "(^|/)\\.github/workflows/ci\\.yml$"
      ],
      "matchStrings": [
        "UV_VERSION\\s*[:=]\\s*\"(?<currentValue>[^\"]+)\"\\s+#\\s+renovate:\\s+depName=(?<depName>\\S+)\\s+datasource=(?<datasource>\\S+)"
      ]
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)pyproject\\.toml$"],
      "matchStrings": [
        "build_command\\s*=\\s*\"pipx install \\\"uv==(?<currentValue>[^\"]+)\\\" && uv build\""
      ],
      "depNameTemplate": "uv",
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "fileMatch": ["(^|/)\\.gitpod\\.yml$"],
      "matchStrings": ["pipx install \\\"uv==(?<currentValue>[^\"]+)\\\""],
      "depNameTemplate": "uv",
      "datasourceTemplate": "pypi"
    }
  ]
}
